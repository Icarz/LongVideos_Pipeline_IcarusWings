# Copy to .env and fill in. Modules call load_dotenv() themselves.

# --- Script + beats (Claude) ---
ANTHROPIC_API_KEY=

# --- Voiceover (ElevenLabs) ---
ELEVENLABS_API_KEY=

# --- Forced alignment for word timings (Groq Whisper) ---
GROQ_API_KEY=

# --- Stock footage (CC0 / no-attribution) ---
PEXELS_API_KEY=
PIXABAY_API_KEY=
COVERR_API_KEY=

# --- Storage (Cloudflare R2, S3-compatible) ---
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_URL=

# --- YouTube Data API (OAuth) ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
